{
  "name": "lazybrain",
  "version": "0.2.0",
  "description": "HTML-first persistent memory for LLM agents — CLI-driven, queryable without LLM calls, local-first with optional public publishing.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "lazybrain": "./dist/bin/lazybrain.js"
  },
  "files": [
    "dist/",
    "examples/brain-ui/",
    "plugins/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "esbuild bin/lazybrain.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/bin/lazybrain.js --packages=external --banner:js=\"#!/usr/bin/env node\"",
    "dev": "tsx bin/lazybrain.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src bin tests",
    "format": "biome format --write src bin tests",
    "typecheck": "tsc --noEmit",
    "download-models": "tsx scripts/download-models.ts",
    "install:lazybrain": "tsx scripts/install.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "memory",
    "claude-code",
    "html",
    "cli",
    "persistent-memory",
    "second-brain",
    "rag",
    "knowledge-graph"
  ],
  "author": "LazyGod75",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LazyGod75/LazyBrain.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.1",
    "commander": "^12.1.0",
    "linkedom": "^0.18.5",
    "pino": "^9.5.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "tiktoken": "^1.0.22",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
